{
  "name": "yt-dlp-gui",
  "private": true,
  "version": "0.3.1",
  "description": "A modern, cross-platform desktop GUI for yt-dlp — download videos from YouTube, Bilibili, Twitter and 1000+ sites. Built with Tauri 2 + Vue 3.",
  "keywords": [
    "yt-dlp",
    "yt-dlp-gui",
    "youtube-downloader",
    "video-downloader",
    "tauri",
    "vue",
    "desktop-app",
    "bilibili",
    "twitter",
    "cross-platform",
    "gui"
  ],
  "author": {
    "name": "imsyy",
    "url": "https://github.com/imsyy"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imsyy/yt-dlp-gui"
  },
  "homepage": "https://github.com/imsyy/yt-dlp-gui#readme",
  "bugs": {
    "url": "https://github.com/imsyy/yt-dlp-gui/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,scss,css,json}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "@vueuse/core": "^14.2.1",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.23",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/mdi": "^1.2.3",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "naive-ui": "^2.43.2",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.56.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^6.0.3",
    "vue-router": "^5.0.3",
    "vue-tsc": "^2.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}